# ============================================================
#  Źródło – konfiguracja środowiska
#  Skopiuj: cp .env.example .env  (dev)
#  Produkcja: cp .env.example .env  i zmień wszystkie wartości
#  chmod 600 .env  – nigdy nie commituj .env do repo!
# ============================================================


# ── Środowisko ────────────────────────────────────────────────────────────────
# Wartości: development | production | test
ENVIRONMENT=development

# ── Domena (tylko produkcja) ──────────────────────────────────────────────────
# Używana przez Caddy (reverse proxy) i linki w mailach
DOMAIN=zrodlo.parafia.pl

# URL frontendu – wstawiany w linkach e-mail (reset hasła, zaproszenia)
APP_URL=http://localhost:3000


# ── Bezpieczeństwo ────────────────────────────────────────────────────────────
# Minimum 32 losowych znaków. Generuj: openssl rand -hex 32
# ZMIEŃ W PRODUKCJI – ten klucz podpisuje tokeny JWT!
SECRET_KEY=zmien-mnie-w-produkcji-32-znaki!!


# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=zrodlo
POSTGRES_USER=zrodlo
# Dev: dowolne, Prod: openssl rand -base64 32
POSTGRES_PASSWORD=zrodlo

# Pełny URL bazy (uzupełniany automatycznie przez docker-compose, lub ręcznie)
# Format: postgresql+asyncpg://USER:PASS@HOST:PORT/DB
DATABASE_URL=postgresql+asyncpg://zrodlo:zrodlo@localhost:5432/zrodlo


# ── Redis ─────────────────────────────────────────────────────────────────────
# Dev: bez hasła. Prod: openssl rand -base64 32
REDIS_PASSWORD=
REDIS_URL=redis://localhost:6379/0


# ── MinIO (object storage – pliki, skany OCR) ─────────────────────────────────
MINIO_ROOT_USER=zrodlo
# Dev: dowolne, Prod: openssl rand -base64 32
MINIO_ROOT_PASSWORD=zrodlo_secret_2024
MINIO_BUCKET=zrodlo-docs

# Konfiguracja klienta backendu
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=zrodlo
MINIO_SECRET_KEY=zrodlo_secret_2024
MINIO_SECURE=false


# ── OpenAI ────────────────────────────────────────────────────────────────────
# Klucz z https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
# Modele (opcjonalne – wartości domyślne poniżej)
OPENAI_MODEL_SIMPLE=gpt-4o-mini
OPENAI_MODEL_COMPLEX=gpt-4o
OPENAI_EMBEDDING_MODEL=text-embedding-3-small


# ── Qdrant (wektorowa baza wiedzy) ───────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=zrodlo_openai


# ── SMTP (e-maile: reset hasła, zaproszenia) ──────────────────────────────────
# Zostaw puste w dev – system wypisuje maile do konsoli
# Prod: dane od dostawcy (SendGrid, Brevo, własny serwer)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=system@parafia.pl


# ── CORS ─────────────────────────────────────────────────────────────────────
# Lista JSON lub pojedyncza wartość
# Dev: ["http://localhost:3000"]
# Prod: ["https://zrodlo.parafia.pl"]
CORS_ORIGINS=["http://localhost", "http://localhost:3000"]


# ── Limity ───────────────────────────────────────────────────────────────────
# Maksymalny rozmiar uploadu pliku (MB)
MAX_UPLOAD_MB=10


# ── Sentry (monitoring błędów) ────────────────────────────────────────────────
# Zostaw puste, żeby wyłączyć. DSN z https://sentry.io
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1


# ── Backup (tylko produkcja) ──────────────────────────────────────────────────
# Katalog docelowy dla kopii zapasowych
BACKUP_ROOT=/backup/zrodlo
# Opcjonalny webhook Slack/Teams dla powiadomień o wyniku backupu
BACKUP_NOTIFY_URL=https://hooks.slack.com/services/...


# ── Frontend (Next.js) ────────────────────────────────────────────────────────
# URL backendu widoczny z przeglądarki
# Dev: /api (proxy przez Next.js), Prod: https://zrodlo.parafia.pl/api
NEXT_PUBLIC_API_URL=/api
