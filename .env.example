# ============================================================
# Źródło – konfiguracja środowiska
# Skopiuj do .env i uzupełnij wartości
# ============================================================

# --- PostgreSQL ---
POSTGRES_DB=zrodlo
POSTGRES_USER=zrodlo
POSTGRES_PASSWORD=zrodlo

# --- MinIO (obiektowa baza plików) ---
MINIO_ROOT_USER=zrodlo
MINIO_ROOT_PASSWORD=zrodlo_secret_2024
MINIO_BUCKET=zrodlo-docs

# --- Ollama (model językowy) ---
# Modele sprawdzone z polskim: gemma2:2b, llama3.2:3b, mistral:7b
OLLAMA_MODEL=gemma2:2b

# --- Bezpieczeństwo ---
# Minimum 32 znaki losowych – ZMIEŃ W PRODUKCJI
SECRET_KEY=zmien-mnie-w-produkcji-32-znaki!!

# --- Środowisko ---
ENVIRONMENT=development
