# .env.prod.example – zmienne produkcyjne Źródło
# Skopiuj jako .env.prod i wypełnij przed uruchomieniem:
#   cp .env.prod.example .env.prod
#   chmod 600 .env.prod
#
# Nigdy nie commituj .env.prod do repo!

# ── Domena ────────────────────────────────────────────────────────────────────
DOMAIN=zrodlo.parafia.pl

# ── PostgreSQL ────────────────────────────────────────────────────────────────
POSTGRES_DB=zrodlo
POSTGRES_USER=zrodlo
# Wygeneruj: openssl rand -base64 32
POSTGRES_PASSWORD=ZMIEN_NA_SILNE_HASLO_BAZY

# ── Redis ─────────────────────────────────────────────────────────────────────
# Wygeneruj: openssl rand -base64 32
REDIS_PASSWORD=ZMIEN_NA_SILNE_HASLO_REDIS

# ── MinIO (object storage) ────────────────────────────────────────────────────
MINIO_ROOT_USER=zrodlo_admin
# Wygeneruj: openssl rand -base64 32
MINIO_ROOT_PASSWORD=ZMIEN_NA_SILNE_HASLO_MINIO
MINIO_BUCKET=zrodlo-docs

# ── JWT / aplikacja ───────────────────────────────────────────────────────────
# Wygeneruj: openssl rand -hex 32
SECRET_KEY=ZMIEN_NA_KLUCZ_JWT_64_ZNAKI

# ── OpenAI ────────────────────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...

# ── Backup ────────────────────────────────────────────────────────────────────
BACKUP_ROOT=/backup/zrodlo
# Opcjonalny webhook Slack/Teams dla powiadomień o backupie
BACKUP_NOTIFY_URL=https://hooks.slack.com/services/...
